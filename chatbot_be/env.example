# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot_sb
DB_USER=postgres
DB_PASSWORD=your_password

# Optional: Full database connection URL (overrides individual DB_* vars if set)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/chatbot_sb

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secret (if implementing authentication later)
JWT_SECRET=your_jwt_secret_here

# OpenAI Configuration
# NOTE: OPENAI_API_KEY is ALWAYS required for RAG embeddings even when using
#       a non-OpenAI LLM provider (Claude, Gemini, Qwen). The Pinecone index
#       was built with OpenAI text-embedding-3-small — queries must use the
#       same embedding model for accurate similarity scores.
USE_OPENAI=true
OPENAI_API_KEY=
USE_TOOLS=true
OPENAI_MODEL=gpt-4o-mini          # optional
OPENAI_MAX_TOKENS=1024             # optional
OPENAI_TEMPERATURE=0.7             # optional

# Claude (Anthropic) Configuration
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku-20240307    # optional
CLAUDE_MAX_TOKENS=1024                   # optional
CLAUDE_TEMPERATURE=0.7                   # optional

# Gemini (Google) Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash           # optional
GEMINI_MAX_TOKENS=1024                   # optional
GEMINI_TEMPERATURE=0.7                   # optional

# Qwen (HuggingFace) Configuration
HF_API_KEY=
QWEN_MODEL=Qwen/Qwen2.5-7B-Instruct   # optional
QWEN_MAX_TOKENS=1024                    # optional
QWEN_TEMPERATURE=0.7                    # optional

# Default LLM Provider (openai | claude | gemini | qwen)
DEFAULT_LLM_PROVIDER=openai

# RAG / Vector Database (Pinecone + OpenAI Embeddings)
# NOTE: OPENAI_API_KEY is ALWAYS required for embeddings even when using
#       a non-OpenAI LLM provider (Claude, Gemini, Qwen). The Pinecone index
#       was built with OpenAI text-embedding-3-small — queries must use the
#       same embedding model for accurate similarity scores.
PINECONE_API_KEY=
PINECONE_INDEX=chatbot-vn-legal
EMBEDDING_MODEL=text-embedding-3-small   # must match the model used during indexing
EMBEDDING_DIMENSIONS=1536                # must match dimensions used during indexing