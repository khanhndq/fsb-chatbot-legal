{
  "name": "chatbot-backend",
  "version": "1.0.0",
  "description": "Backend for Chatbot Guru with TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:websocket": "jest --testPathPattern=websocket",
    "migrate": "node-pg-migrate up -m src/migrations --ignore-pattern '.*\\.md$'",
    "migrate:down": "node-pg-migrate down -m src/migrations --ignore-pattern '.*\\.md$'",
    "migrate:create": "node-pg-migrate create -m src/migrations -j js",
    "migrate:redo": "node-pg-migrate redo -m src/migrations --ignore-pattern '.*\\.md$'"
  },
  "keywords": [
    "chatbot",
    "express",
    "postgresql",
    "redis",
    "websocket",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@pinecone-database/pinecone": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "openai": "^6.16.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.10",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "node-pg-migrate": "^8.0.4",
    "socket.io-client": "^4.7.4",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
